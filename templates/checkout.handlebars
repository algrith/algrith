<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Order Confirmation – Algrith</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500&family=DM+Mono:wght@400;500&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background-color: #F5F4F0; font-family: 'DM Sans', Arial, sans-serif; color: #1A1A18; padding: 40px 16px; }
    .wrapper { max-width: 560px; margin: 0 auto; }
    .header { padding: 0 0 32px 0; }
    .logo { font-family: 'DM Mono', monospace; font-size: 18px; font-weight: 500; color: #1A1A18; letter-spacing: -0.02em; }
    .card { background: #FFFFFF; border-radius: 16px; overflow: hidden; border: 0.5px solid #E0DED6; }
    .card-top { background: #1A1A18; padding: 40px 36px 36px; }
    .badge { display: inline-block; background: #2ca374; color: #D4EAD9; font-size: 11px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; padding: 5px 14px; border-radius: 100px; margin-bottom: 20px; }
    .card-top h1 { font-size: 26px; font-weight: 500; color: #F5F4F0; line-height: 1.3; letter-spacing: -0.02em; }
    .card-top p { font-size: 14px; color: #888880; margin-top: 10px; line-height: 1.6; }
    .card-body { padding: 32px 36px; }
    .section-label { font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: #AEADA6; margin-bottom: 12px; }
    .plan-block { background: #F5F4F0; border-radius: 12px; padding: 20px 22px; margin-bottom: 24px; }
    .plan-name { font-size: 15px; font-weight: 500; color: #1A1A18; margin-bottom: 2px; }
    .plan-meta { font-size: 12px; color: #888880; margin-bottom: 14px; }
    .feature-row { display: table; width: 100%; padding: 5px 0; }
    .feature-icon { display: table-cell; width: 20px; vertical-align: top; padding-top: 1px; }
    .check-circle { width: 14px; height: 14px; border-radius: 50%; background: #D4EAD9; display: inline-block; text-align: center; line-height: 14px; font-size: 9px; color: #2ca374; }
    .feature-text { display: table-cell; font-size: 12px; color: #6B6A65; vertical-align: top; line-height: 1.5; }
    .divider { height: 0.5px; background: #F0EEE8; margin: 24px 0; }
    .order-table { width: 100%; border-collapse: collapse; }
    .order-table tr td { padding: 9px 0; font-size: 13px; border-bottom: 0.5px solid #F0EEE8; }
    .order-table tr:last-child td { border-bottom: none; }
    .order-table .label { color: #6B6A65; }
    .order-table .value { text-align: right; font-family: 'DM Mono', monospace; color: #1A1A18; }
    .order-table .total-label { color: #1A1A18; font-weight: 500; }
    .order-table .total-value { text-align: right; font-family: 'DM Mono', monospace; font-size: 15px; font-weight: 500; color: #2ca374; }
    .addons-block { background: #F5F4F0; border-radius: 12px; padding: 16px 20px; margin-bottom: 24px; }
    .addon-row { display: table; width: 100%; padding: 6px 0; border-bottom: 0.5px solid #E8E6E0; }
    .addon-row:last-child { border-bottom: none; }
    .addon-text { display: table-cell; font-size: 12px; color: #6B6A65; vertical-align: middle; }
    .addon-price { display: table-cell; text-align: right; font-family: 'DM Mono', monospace; font-size: 12px; color: #1A1A18; vertical-align: middle; }
    .addon-cycle { font-size: 10px; color: #AEADA6; margin-left: 4px; }
    .cta-button { display: block; width: 100%; background: #1A1A18; color: #F5F4F0; text-align: center; padding: 14px; border-radius: 10px; font-size: 14px; font-weight: 500; text-decoration: none; letter-spacing: -0.01em; margin-top: 24px; }
    .help-block { background: #F5F4F0; border-radius: 10px; padding: 16px 20px; margin-top: 20px; font-size: 12px; color: #888880; line-height: 1.6; }
    .help-block a { color: #2ca374; text-decoration: none; }
    .footer { padding: 28px 0 0; font-size: 11px; color: #AEADA6; line-height: 1.8; text-align: center; }
    .footer a { color: #AEADA6; text-decoration: underline; }
    .enterprise-note { font-size: 12px; color: #888880; font-style: italic; margin-top: 4px; }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="header">
      <div class="logo">
        <img src="https://algrith.com/images/logo/algrith-logo-dark.png" alt="algrith" width="120" />
      </div>
    </div>

    <div class="card">
      <div class="card-top">
        <div class="badge">&#10003;&nbsp; Order confirmed</div>
        <h1>Your project is now underway.</h1>
        <p>Hi {{customer.name}}, thanks for choosing Algrith. Here's a summary of what you've ordered — we'll be in touch shortly to kick things off.</p>
      </div>

      <div class="card-body">

        {{!-- Plan block --}}
        <div class="section-label">Your plan</div>
        <div class="plan-block">
          <div class="plan-name">{{plan.name}} Plan</div>
          <div class="plan-meta">
            {{#if plan.one_time_payment}}
              One-time payment
            {{else}}
              Custom engagement &middot; Quote-based
            {{/if}}
            &middot; Ref: {{order.reference}}
          </div>

          {{#each plan.features}}
            <div class="feature-row">
              <div class="feature-icon"><span class="check-circle">&#10003;</span></div>
              <div class="feature-text">{{this}}</div>
            </div>
          {{/each}}
        </div>

        {{!-- Addons block — only shown if addons were selected --}}
        {{#if addons.length}}
          <div class="section-label">Add-ons selected</div>
          <div class="addons-block">
            {{#each addons}}
              <div class="addon-row">
                <div class="addon-text">{{this.text}}</div>
                <div class="addon-price">
                  {{#if (eq this.billing_cycle 'one-time')}}
                    ${{this.price}}
                    <span class="addon-cycle">once</span>
                  {{else}}
                    ${{this.price}}
                    <span class="addon-cycle">/mo</span>
                  {{/if}}
                </div>
              </div>
            {{/each}}
          </div>
        {{/if}}

        {{!-- Order summary --}}
        <div class="section-label">Order summary</div>
        <table class="order-table">
          <tr>
            <td class="label">Plan</td>
            <td class="value">
              {{plan.name}}
              {{#if plan.one_time_payment}}— ${{plan.price}}{{else}}— Custom quote{{/if}}
            </td>
          </tr>
          {{#if addons.length}}
            <tr>
              <td class="label">Add-ons</td>
              <td class="value">${{order.addons_total}}</td>
            </tr>
          {{/if}}
          <tr>
            <td class="label">Reference</td>
            <td class="value">{{order.reference}}</td>
          </tr>
          <tr>
            <td class="label">Date</td>
            <td class="value">{{order.date}}</td>
          </tr>
          {{#if plan.one_time_payment}}
            <tr>
              <td class="total-label">Total paid</td>
              <td class="total-value">${{order.total}}</td>
            </tr>
          {{else}}
            <tr>
              <td class="total-label">Amount</td>
              <td class="total-value">To be invoiced</td>
            </tr>
          {{/if}}
        </table>

        {{!-- Enterprise-specific note --}}
        {{#unless plan.one_time_payment}}
          <p class="enterprise-note" style="margin-top: 14px;">
            Our team will reach out within 1–2 business days to discuss your project scope and send a formal proposal.
          </p>
        {{/unless}}

        <a href="{{links.dashboard}}" class="cta-button">Go to dashboard &rarr;</a>

        <div class="help-block">
          Questions about your order? Reply to this email or reach us at
          <a href="mailto:{{links.support_email}}">{{links.support_email}}</a>.
          {{!-- You can review your order anytime from your
          <a href="{{links.billing}}">account settings</a>. --}}
        </div>
      </div>
    </div>

    <div class="footer">
      <p>Algrith</p>
      <p style="margin-top: 4px;">
        {{!-- <a href="{{links.unsubscribe}}">Unsubscribe</a> &middot; --}}
        <a href="{{links.terms}}">Terms of Service</a> &middot;
        <a href="{{links.privacy}}">Privacy policy</a>
      </p>
    </div>
  </div>
</body>
</html>
