<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Reset your password — Algrith</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body, #bodyTable {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      background-color: #f0ede8;
      font-family: 'DM Sans', Arial, sans-serif;
      color: #1a1a18;
    }

    img {
      border: 0;
      display: block;
      outline: none;
    }

    a {
      text-decoration: none;
    }

    .eyebrow {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #888880;
      margin-bottom: 16px;
      display: block;
    }

    .headline {
      font-family: 'DM Serif Display', Georgia, serif;
      font-size: 36px;
      line-height: 1.15;
      color: #1a1a18;
      margin-bottom: 24px;
    }

    .headline em {
      font-style: italic;
      color: #5a7a2e;
    }

    .body-text {
      font-size: 15px;
      font-weight: 300;
      line-height: 1.75;
      color: #44443e;
      margin-bottom: 32px;
    }

    .body-text strong {
      font-weight: 500;
      color: #1a1a18;
    }

    .cta-btn {
      display: inline-block;
      background-color: #1a1a18;
      color: #2ca374 !important;
      font-family: 'DM Sans', Arial, sans-serif;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-decoration: none;
      padding: 16px 32px;
      border-radius: 8px;
    }

    .header-tag {
      font-size: 11px;
      font-weight: 500;
      color: #2ca374;
      letter-spacing: 2px;
      text-transform: uppercase;
      border: 1px solid #2ca37433;
      padding: 4px 10px;
      border-radius: 100px;
      white-space: nowrap;
    }

    .footer-link {
      font-size: 12px;
      color: #666660 !important;
      text-decoration: none;
      font-weight: 300;
    }

    .fallback-text {
      font-size: 12px;
      font-weight: 300;
      color: #888880;
      line-height: 1.7;
      word-break: break-all;
    }

    .fallback-link {
      color: #5a7a2e !important;
      text-decoration: underline;
      font-weight: 400;
    }
  </style>
</head>
<body>
  <table id="bodyTable" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td align="center" style="padding: 48px 16px; background-color: #f0ede8;">

        <!-- Wrapper -->
        <table width="560" cellpadding="0" cellspacing="0" border="0" style="max-width: 560px;">

          <!-- ===== HEADER ===== -->
          <tr>
            <td style="border-radius: 16px 16px 0 0; background-color: #1a1a18; padding: 32px 48px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="vertical-align: middle;">
                    <img
                      src="https://algrith.com/images/logo/algrith-logo-light.png"
                      alt="Algrith"
                      width="120"
                    />
                  </td>
                  <td align="right" style="vertical-align: middle;">
                    <span class="header-tag">Password Reset</span>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ===== BODY ===== -->
          <tr>
            <td style="background-color: #ffffff; padding: 48px;">

              <!-- Eyebrow -->
              <p class="eyebrow">Account Security</p>

              <!-- Headline -->
              <h1 class="headline">
                Reset your<br/>
                <em>password</em>.
              </h1>

              <!-- Divider -->
              <table cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 24px;">
                <tr>
                  <td style="width: 40px; height: 3px; background-color: #2ca374; border-radius: 2px; font-size: 0; line-height: 0;">&nbsp;</td>
                </tr>
              </table>

              <!-- Body text -->
              <p class="body-text">
                Hi <strong>{{name}}</strong>, we received a request to reset the password
                for your <strong>Algrith</strong> account. Click the button below to choose
                a new password and regain access to your account.
              </p>

              <!-- CTA Button -->
              <table cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 36px;">
                <tr>
                  <td align="left" style="border-radius: 8px; background-color: #1a1a18;">
                    <a href="{{password_reset_url}}" class="cta-btn">
                      Reset My Password &rarr;
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Expiry Notice -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 32px;">
                <tr>
                  <td style="background-color: #f7f6f2; border-left: 3px solid #2ca374; border-radius: 0 8px 8px 0; padding: 16px 20px;">
                    <p style="font-size: 13px; color: #44443e; line-height: 1.6; font-family: 'DM Sans', Arial, sans-serif;">
                      This reset link will expire in <strong style="color: #1a1a18;">{{expires_in}}</strong>.
                      If you did not request a password reset, you can safely ignore this email —
                      your password will remain unchanged.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Security Notice -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 32px;">
                <tr>
                  <td style="background-color: #fff8f0; border-left: 3px solid #e8834a; border-radius: 0 8px 8px 0; padding: 16px 20px;">
                    <p style="font-size: 13px; color: #44443e; line-height: 1.6; font-family: 'DM Sans', Arial, sans-serif;">
                      <strong style="color: #1a1a18;">Security tip:</strong> Algrith will never ask
                      for your password via email. If you did not make this request, please
                      <a href="mailto:{{support}}" style="color: #5a7a2e; text-decoration: underline;">contact our support team</a> immediately.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Fallback Link -->
              <p class="fallback-text">
                Button not working? Copy and paste this link into your browser:<br/>
                <a href="{{password_reset_url}}" class="fallback-link">{{password_reset_url}}</a>
              </p>

            </td>
          </tr>

          <!-- ===== FOOTER ===== -->
          <tr>
            <td style="background-color: #1a1a18; border-radius: 0 0 16px 16px; padding: 24px 48px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="vertical-align: middle; font-size: 12px; color: #666660; font-family: 'DM Sans', Arial, sans-serif; font-weight: 300;">
                    &copy; {{year}} Algrith. All rights reserved.
                  </td>
                  <td align="right" style="vertical-align: middle;">
                    <table cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding-left: 20px;">
                          <a href="{{privacy_url}}" class="footer-link">Privacy</a>
                        </td>
                        <td style="padding-left: 20px;">
                          <a href="{{terms_url}}" class="footer-link">Terms</a>
                        </td>
                        <td style="padding-left: 20px;">
                          <a href="mailto:{{support}}" class="footer-link">Support</a>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
        <!-- End Wrapper -->
      </td>
    </tr>
  </table>
</body>
</html>
